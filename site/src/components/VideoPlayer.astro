---
/**
 * VideoPlayer — componente reutilizable para incrustar videos.
 *
 * Props:
 *   src       — ruta relativa al archivo .mp4 (desde /)
 *   caption   — texto descriptivo debajo del video (opcional)
 *   poster    — imagen de portada opcional (opcional)
 *   autoplay  — autoplay + muted (opcional, default: false)
 *   loop      — loop (opcional, default: false)
 *   width     — "portrait" | "landscape" | "full" (default: "portrait")
 */
export interface Props {
  src: string;
  caption?: string;
  poster?: string;
  autoplay?: boolean;
  loop?: boolean;
  width?: 'portrait' | 'landscape' | 'full';
}

const {
  src,
  caption,
  poster,
  autoplay = false,
  loop = false,
  width = 'portrait',
} = Astro.props;

const aspectRatio = width === 'portrait' ? '100 / 177.78' : width === 'landscape' ? '16 / 9' : 'auto';
const maxWidth = width === 'full' ? '100%' : width === 'landscape' ? '800px' : '420px';
const margin = width === 'full' ? '0' : '0 auto';
const attrs: string[] = [];
if (autoplay) attrs.push('autoplay muted');
else if (loop) attrs.push('loop');
else attrs.push('controls');
---

<div
  class="video-player"
  style={`max-width: ${maxWidth}; margin: ${margin}; margin-bottom: 1.5rem;`}
>
  <video
    width={width === 'portrait' ? 1080}
    height={width === 'portrait' ? 1920}
    style={width === 'portrait' ? `aspect-ratio: ${aspectRatio};` : ''}
    {...(poster ? { poster } : {})}
  >
    <source src={src} type="video/mp4" />
    Tu navegador no soporta video HTML5.
  </video>
  {caption && <p class="video-caption">{caption}</p>}
</div>

<style>
  .video-player {
    text-align: center;
  }

  .video-player video {
    border-radius: 8px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
    width: 100%;
    background: #000;
  }

  .video-player.portrait video {
    max-height: 70vh;
  }

  .video-caption {
    font-size: 0.875rem;
    color: var(--sl-color-gray-3);
    margin-top: 0.5rem;
    font-style: italic;
  }
</style>
